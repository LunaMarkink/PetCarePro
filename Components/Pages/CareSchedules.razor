@page "/careschedules"

@using PetCarePro.Classes
@using PetCarePro.Data
@using Microsoft.EntityFrameworkCore

@inject AppDbContext Db

<div class="page-header">
    <div>
        <h1>Care Schedules</h1>
        <p>Manage feeding, medication and care notes for pets.</p>
    </div>

    <a href="/careschedules/new" class="btn btn-primary">
        New Care Schedule
    </a>
</div>

<div class="row g-4">
    @foreach (var careSchedule in careSchedules)
    {
        <div class="col-lg-4 col-md-6">
            <div class="entity-card">
                <div class="entity-card-header">
                    <div>
                        <h4>@(careSchedule.Pet?.Name ?? $"Pet ID {careSchedule.PetId}")</h4>
                        <span>Care Schedule ID: @careSchedule.CareScheduleId</span>
                    </div>

                    <div class="entity-icon care-icon">
                        <i class="bi bi-clipboard2-heart-fill"></i>
                    </div>
                </div>

                <div class="entity-info">
                    <p><strong>Feeding:</strong> @careSchedule.Feeding</p>
                    <p><strong>Medication:</strong> @careSchedule.Medication</p>
                    <p><strong>Notes:</strong> @careSchedule.Notes</p>
                </div>

                <div class="entity-actions">
                    <a class="btn btn-outline-primary btn-sm"
                       href="/careschedules/edit/@careSchedule.CareScheduleId">
                        Edit
                    </a>

                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => Delete(careSchedule)">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<CareSchedule> careSchedules = new();

    protected override void OnInitialized()
    {
        careSchedules = Db.CareSchedules
            .Include(c => c.Pet)
            .ToList();
    }

    private async Task Delete(CareSchedule careSchedule)
    {
        Db.CareSchedules.Remove(careSchedule);
        await Db.SaveChangesAsync();
        careSchedules.Remove(careSchedule);
    }
}
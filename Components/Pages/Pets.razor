@page "/pets"

@using PetCarePro.Classes
@using PetCarePro.Data

@inject AppDbContext Db

<div class="page-header">
    <div>
        <h1>Pets</h1>
        <p>Manage all registered pets.</p>
    </div>

    <a href="/pets/new" class="btn btn-success">
        New Pet
    </a>
</div>

<div class="row g-4">
    @foreach (var pet in pets)
    {
        <div class="col-lg-4 col-md-6">
            <div class="entity-card">
                <div class="entity-card-header">
                    <div>
                        <h4>@pet.Name</h4>
                        <span>Pet ID: @pet.PetId</span>
                    </div>

                    <div class="entity-icon pet-icon">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </div>
                </div>

                <div class="entity-info">
                    <p><strong>Species:</strong> @pet.Species</p>
                    <p><strong>Breed:</strong> @pet.Breed</p>
                    <p><strong>Gender:</strong> @pet.Gender</p>
                    <p><strong>Chip Number:</strong> @pet.ChipNumber</p>
                    <p><strong>Client ID:</strong> @pet.ClientId</p>
                </div>

                <div class="entity-actions">
                    <a class="btn btn-outline-primary btn-sm"
                       href="/pets/edit/@pet.PetId">
                        Edit
                    </a>

                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => Delete(pet)">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Pet> pets = new();

    protected override void OnInitialized()
    {
        pets = Db.Pets.ToList();
    }

    private async Task Delete(Pet pet)
    {
        Db.Pets.Remove(pet);
        await Db.SaveChangesAsync();
        pets.Remove(pet);
    }
}
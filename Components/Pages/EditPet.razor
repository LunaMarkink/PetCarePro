@page "/pets/edit/{Id:int}"
@page "/pets/new"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]

@using PetCarePro.Classes
@using PetCarePro.Data

@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "New Pet" : "Edit Pet")</PageTitle>
<div class="form-container">
    <div class="form-card">

        <h1 class="form-title">
            @(Id == 0 ? "New Pet" : "Edit Pet")
        </h1>

        <p class="form-subtitle">
            @(Id == 0
                ? "Add a new pet to the PetCarePro system."
                : "Update the pet's information.")
        </p>

        @if (pet is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <EditForm Model="pet" OnValidSubmit="SavePet" FormName="PetForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="pet.Name" />
                    <ValidationMessage For="@(() => pet.Name)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Species</label>
                    <InputText class="form-control" @bind-Value="pet.Species" />
                    <ValidationMessage For="@(() => pet.Species)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Breed</label>
                    <InputText class="form-control" @bind-Value="pet.Breed" />
                    <ValidationMessage For="@(() => pet.Breed)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Date of Birth</label>
                    <InputDate class="form-control"
               @bind-Value="pet.DateOfBirth" />
                    <ValidationMessage For="@(() => pet.DateOfBirth)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Gender</label>
                    <InputText class="form-control" @bind-Value="pet.Gender" />
                    <ValidationMessage For="@(() => pet.Gender)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Chip Number</label>
                    <InputText class="form-control" @bind-Value="pet.ChipNumber" />
                    <ValidationMessage For="@(() => pet.ChipNumber)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Medical History</label>
                    <InputText class="form-control" @bind-Value="pet.MedicalHistory" />
                    <ValidationMessage For="@(() => pet.MedicalHistory)" />
                </div>

                 <div class="mb-4">
                    <label class="form-label">Owner</label>

                <InputSelect class="form-select" @bind-Value="pet.ClientId">
        <option value="0">-- Select an owner --</option>
        @foreach (var client in clients)
        {
            <option value="@client.ClientId">@client.Name</option>
        }
    </InputSelect>

    <ValidationMessage For="@(() => pet.ClientId)" />
</div>

                <div class="form-buttons">
                    <button class="btn btn-success px-4" type="submit">
                        <i class="bi bi-check-circle-fill"></i>
                        Save
                    </button>

                    <a href="/pets" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i>
                        Cancel
                    </a>
                </div>
            </EditForm>
        }

    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Pet? pet;
    private List<Client> clients = new();

protected override async Task OnInitializedAsync()
{
    clients = await Db.Clients
        .OrderBy(c => c.Name)
        .ToListAsync();

    pet = Id == 0
        ? new Pet()
        : await Db.Pets.FindAsync(Id);
}

    private async Task SavePet()
    {
        if (Id == 0)
        {
            Db.Pets.Add(pet!);
        }

        await Db.SaveChangesAsync();
        Navigation.NavigateTo("/pets");
    }
}
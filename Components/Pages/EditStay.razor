@page "/stays/edit/{Id:int}"
@page "/stays/new"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using PetCarePro.Classes
@using PetCarePro.Data


@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "New Stay" : "Edit Stay")</PageTitle>

<div class="form-container">
    <div class="form-card">

        <h1 class="form-title">
            @(Id == 0 ? "New Stay" : "Edit Stay")
        </h1>

        <p class="form-subtitle">
            @(Id == 0
                ? "Add a new stay to the PetCarePro system."
                : "Update the stay information.")
        </p>

        @if (stay is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <EditForm Model="stay" OnValidSubmit="SaveStay" FormName="StayForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Pet ID</label>
                    <InputNumber class="form-control" @bind-Value="stay.PetId" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Start Date</label>
                    <InputDate class="form-control" @bind-Value="stay.StartDate" />
                </div>

                <div class="mb-3">
                    <label class="form-label">End Date</label>
                    <InputDate class="form-control" @bind-Value="stay.EndDate" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Kennel Number</label>
                    <InputText class="form-control" @bind-Value="stay.KennelNumber" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Status</label>
                    <InputText class="form-control" @bind-Value="stay.Status" />
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-check-circle-fill"></i>
                        Save
                    </button>

                    <a href="/stays" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i>
                        Cancel
                    </a>
                </div>
            </EditForm>
        }

    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Stay? stay;

    protected override async Task OnInitializedAsync()
    {
        if (Id == 0)
        {
            stay = new Stay
            {
                StartDate = DateTime.Today,
                EndDate = DateTime.Today.AddDays(1),
                KennelNumber = "",
                Status = ""
            };
        }
        else
        {
            stay = await Db.Stays.FindAsync(Id);
        }
    }

    private async Task SaveStay()
    {
        if (Id == 0)
        {
            Db.Stays.Add(stay!);
        }

        await Db.SaveChangesAsync();
        Navigation.NavigateTo("/stays");
    }
}
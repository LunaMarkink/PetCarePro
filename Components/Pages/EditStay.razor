@page "/stays/edit/{Id:int}"
@page "/stays/new"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using PetCarePro.Classes
@using PetCarePro.Data


@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "New Stay" : "Edit Stay")</PageTitle>

<div class="form-container">
    <div class="form-card">

        <h1 class="form-title">
            @(Id == 0 ? "New Stay" : "Edit Stay")
        </h1>

        <p class="form-subtitle">
            @(Id == 0
                ? "Add a new stay to the PetCarePro system."
                : "Update the stay information.")
        </p>
        @if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

        @if (stay is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <EditForm Model="stay" OnValidSubmit="SaveStay" FormName="StayForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
    <label class="form-label">Pet</label>

    <InputSelect class="form-select" @bind-Value="stay.PetId">
        <option value="0">-- Select a pet --</option>

        @foreach (var pet in pets)
        {
            <option value="@pet.PetId">@pet.Name</option>
        }
    </InputSelect>

    <ValidationMessage For="@(() => stay.PetId)" />
</div>

                <div class="mb-3">
                    <label class="form-label">Start Date</label>
                    <InputDate class="form-control" @bind-Value="stay.StartDate" />
                    <ValidationMessage For="@(() => stay.StartDate)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">End Date</label>
                    <InputDate class="form-control" @bind-Value="stay.EndDate" />
                    <ValidationMessage For="@(() => stay.EndDate)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Kennel Number</label>
                    <InputText class="form-control" @bind-Value="stay.KennelNumber" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Status</label>
                    <InputText class="form-control" @bind-Value="stay.Status" />
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-check-circle-fill"></i>
                        Save
                    </button>

                    <a href="/stays" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i>
                        Cancel
                    </a>
                </div>
            </EditForm>
        }

    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private List<Pet> pets = new();

    private Stay? stay;

    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        pets = await Db.Pets
    .OrderBy(p => p.Name)
    .ToListAsync();

        if (Id == 0)
        {
            stay = new Stay
            {
                StartDate = DateTime.Today,
                EndDate = DateTime.Today.AddDays(1),
                KennelNumber = "",
                Status = ""
            };
        }
        else
        {
            stay = await Db.Stays.FindAsync(Id);
        }
    }

    private async Task SaveStay()
{
    errorMessage = null;

    if (stay is null)
    {
        errorMessage = "The stay could not be loaded.";
        return;
    }

    if (stay.EndDate < stay.StartDate)
    {
        errorMessage = "The end date cannot be before the start date.";
        return;
    }

    var overlappingStayExists = await Db.Stays.AnyAsync(existingStay =>
        existingStay.StayId != stay.StayId &&
        existingStay.PetId == stay.PetId &&
        stay.StartDate <= existingStay.EndDate &&
        stay.EndDate >= existingStay.StartDate);

    if (overlappingStayExists)
    {
        errorMessage =
            "This pet already has a stay that overlaps with the selected period.";
        return;
    }

    try
    {
        if (Id == 0)
        {
            Db.Stays.Add(stay);
        }

        await Db.SaveChangesAsync();
        Navigation.NavigateTo("/stays");
    }
    catch (Exception)
    {
        errorMessage =
            "Something went wrong while saving the stay. Please try again.";
    }
}
}
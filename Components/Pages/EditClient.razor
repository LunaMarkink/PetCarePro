@page "/clients/edit/{Id:int}"
@page "/clients/new"
@rendermode InteractiveServer

@using PetCarePro.Classes
@using PetCarePro.Data

@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "New Client" : "Edit Client")</PageTitle>

<div class="form-container">

    <div class="form-card">

        <h1 class="form-title">
            @(Id == 0 ? "New Client" : "Edit Client")
        </h1>

        <p class="form-subtitle">
            @(Id == 0
                ? "Add a new client to the PetCarePro system."
                : "Update the client's information.")
        </p>

        @if (client is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <EditForm Model="client" OnValidSubmit="SaveClient" FormName="ClientForm">

                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control"
                               @bind-Value="client.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <InputText class="form-control"
                               @bind-Value="client.Address" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Phone Number</label>
                    <InputText class="form-control"
                               @bind-Value="client.PhoneNumber" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Email Address</label>
                    <InputText class="form-control"
                               @bind-Value="client.Email" />
                </div>

                <div class="form-buttons">

                    <button class="btn btn-primary px-4"
                            type="submit">

                        <i class="bi bi-check-circle-fill"></i>
                        Save

                    </button>

                    <a href="/clients"
                       class="btn btn-outline-secondary px-4">

                        <i class="bi bi-arrow-left"></i>
                        Cancel

                    </a>

                </div>

            </EditForm>
        }

    </div>

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Client? client;

    protected override async Task OnInitializedAsync()
    {
        client = Id == 0
            ? new Client()
            : await Db.Clients.FindAsync(Id);
    }

    private async Task SaveClient()
    {
        if (Id == 0)
        {
            Db.Clients.Add(client!);
        }

        await Db.SaveChangesAsync();

        Navigation.NavigateTo("/clients");
    }

}
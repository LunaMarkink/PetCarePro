@page "/careschedules/edit/{Id:int}"
@page "/careschedules/new"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using PetCarePro.Classes
@using PetCarePro.Data


@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "New Care Schedule" : "Edit Care Schedule")</PageTitle>

<div class="form-container">
    <div class="form-card">

        <h1 class="form-title">
            @(Id == 0 ? "New Care Schedule" : "Edit Care Schedule")
        </h1>

        <p class="form-subtitle">
            @(Id == 0
                ? "Add a new care schedule to the PetCarePro system."
                : "Update the care schedule information.")
        </p>

        @if (careSchedule is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <EditForm Model="careSchedule"
                      OnValidSubmit="SaveCareSchedule"
                      FormName="CareScheduleForm">

                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Pet ID</label>
                    <InputNumber class="form-control"
                                 @bind-Value="careSchedule.PetId" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Feeding</label>
                    <InputText class="form-control"
                               @bind-Value="careSchedule.Feeding" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Medication</label>
                    <InputText class="form-control"
                               @bind-Value="careSchedule.Medication" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Notes</label>
                    <InputText class="form-control"
                               @bind-Value="careSchedule.Notes" />
                </div>

                <div class="form-buttons">

                    <button type="submit"
                            class="btn btn-primary px-4">

                        <i class="bi bi-check-circle-fill"></i>
                        Save

                    </button>

                    <a href="/careschedules"
                       class="btn btn-outline-secondary px-4">

                        <i class="bi bi-arrow-left"></i>
                        Cancel

                    </a>

                </div>

            </EditForm>
        }

    </div>
</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private CareSchedule? careSchedule;

    protected override async Task OnInitializedAsync()
    {
        careSchedule = Id == 0
            ? new CareSchedule
            {
                Feeding = "",
                Medication = "",
                Notes = ""
            }
            : await Db.CareSchedules.FindAsync(Id);
    }

    private async Task SaveCareSchedule()
    {
        if (Id == 0)
        {
            Db.CareSchedules.Add(careSchedule!);
        }

        await Db.SaveChangesAsync();

        Navigation.NavigateTo("/careschedules");
    }

}
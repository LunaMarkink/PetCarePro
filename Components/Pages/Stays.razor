@page "/stays"

@using PetCarePro.Classes
@using PetCarePro.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

@inject AppDbContext Db

<div class="page-header">
    <div>
        <h1>Stays</h1>
        <p>Manage all planned and active pet stays.</p>
    </div>

    <a href="/stays/new" class="btn btn-warning">
        New Stay
    </a>
</div>

<div class="mb-4">
    <input type="text"
           class="form-control"
           placeholder="Search by pet, kennel or status..."
           @bind="searchTerm"
           @bind:event="oninput" />
</div>

<div class="row g-4">
    @foreach (var stay in filteredStays)
    {
        <div class="col-lg-4 col-md-6">
            <div class="entity-card">
                <div class="entity-card-header">
                    <div>
                        <h4>@(stay.Pet?.Name ?? $"Pet ID {stay.PetId}")</h4>
                        <span>Stay ID: @stay.StayId</span>
                    </div>

                    <div class="entity-icon stay-icon">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                </div>

                <div class="entity-info">
                    <p><strong>Start Date:</strong> @stay.StartDate.ToShortDateString()</p>
                    <p><strong>End Date:</strong> @stay.EndDate.ToShortDateString()</p>
                    <p><strong>Kennel:</strong> @stay.KennelNumber</p>
                    <p><strong>Status:</strong> <span class="status-badge">@stay.Status</span></p>
                </div>

                <div class="entity-actions">
                    <a class="btn btn-outline-primary btn-sm"
                       href="/stays/edit/@stay.StayId">
                        Edit
                    </a>

                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => Delete(stay)">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Stay> stays = new();

    private string searchTerm = string.Empty;
private IEnumerable<Stay> filteredStays =>
    string.IsNullOrWhiteSpace(searchTerm)
        ? stays
        : stays.Where(stay =>
            (stay.Pet?.Name?.Contains(
                searchTerm,
                StringComparison.OrdinalIgnoreCase) ?? false) ||
            stay.KennelNumber.Contains(
                searchTerm,
                StringComparison.OrdinalIgnoreCase) ||
            stay.Status.Contains(
                searchTerm,
                StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        stays = Db.Stays
            .Include(s => s.Pet)
            .ToList();
    }

    private async Task Delete(Stay stay)
    {
        Db.Stays.Remove(stay);
        await Db.SaveChangesAsync();
        stays.Remove(stay);
    }
}

@page "/users/edit/{Id:int}"
@page "/users/new"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrator")]

@using PetCarePro.Classes
@using PetCarePro.Data


@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "New User" : "Edit User")</PageTitle>

<div class="form-container">
    <div class="form-card">

        <h1 class="form-title">
            @(Id == 0 ? "New User" : "Edit User")
        </h1>

        <p class="form-subtitle">
            @(Id == 0
                ? "Add a new system user to PetCarePro."
                : "Update the user information.")
        </p>

        @if (user is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <EditForm Model="user" OnValidSubmit="SaveUser" FormName="UserForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <InputText class="form-control" @bind-Value="user.Username" />
                    <ValidationMessage For="@(() => user.Username)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText class="form-control" @bind-Value="user.Password" />
                    <ValidationMessage For="@(() => user.Password)" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Role</label>
                    <InputText class="form-control" @bind-Value="user.Role" />
                    <ValidationMessage For="@(() => user.Role)" />
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-dark px-4">
                        <i class="bi bi-check-circle-fill"></i>
                        Save
                    </button>

                    <a href="/users" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i>
                        Cancel
                    </a>
                </div>
            </EditForm>
        }

    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private User? user;

    protected override async Task OnInitializedAsync()
    {
        user = Id == 0
            ? new User
            {
                Username = "",
                Password = "",
                Role = ""
            }
            : await Db.Users.FindAsync(Id);
    }

    private async Task SaveUser()
    {
        if (Id == 0)
        {
            Db.Users.Add(user!);
        }

        await Db.SaveChangesAsync();
        Navigation.NavigateTo("/users");
    }
}
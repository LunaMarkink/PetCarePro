@page "/users/edit/{Id:int}"
@page "/users/new"
@rendermode InteractiveServer

@using PetCarePro.Classes
@using PetCarePro.Data

@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "New User" : "Edit User")</PageTitle>

<h3>@(Id == 0 ? "New User" : "Edit User")</h3>

@if (user is null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="user" OnValidSubmit="SaveUser">

        <div class="mb-3">
            <label class="form-label">Username</label>
            <InputText class="form-control" @bind-Value="user.Username" />
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <InputText class="form-control" @bind-Value="user.Password" />
        </div>

        <div class="mb-3">
            <label class="form-label">Role</label>
            <InputText class="form-control" @bind-Value="user.Role" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-secondary ms-2" href="/users">Cancel</a>

    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private User? user;

    protected override async Task OnInitializedAsync()
    {
        user = Id == 0 ? new User() : await Db.Users.FindAsync(Id);
    }

    private async Task SaveUser()
    {
        if (Id == 0)
        {
            Db.Users.Add(user!);
        }

        await Db.SaveChangesAsync();
        Navigation.NavigateTo("/users");
    }
}
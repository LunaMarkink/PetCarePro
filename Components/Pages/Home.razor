@page "/"

@using PetCarePro.Data
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AppDbContext Db

<PageTitle>PetCarePro Dashboard</PageTitle>

<div class="container-fluid dashboard-page">

    <div class="dashboard-hero">
        <div>
            <h1>Welcome to PetCarePro</h1>
            <p>This is your dashboard where you can manage clients, pets, stays, care schedules and users.</p>
        </div>
    </div>

    <div class="row g-4 mt-2">

        <div class="col-lg-3 col-md-6">
            <div class="dashboard-card">
                <div class="card-top">
                    <div>
                        <h6>Clients</h6>
                        <h2>@Db.Clients.Count()</h2>
                    </div>
                    <div class="card-icon">
                        <i class="bi bi-person-fill"></i>
                    </div>
                </div>
                <a href="/clients" class="card-link">View Details</a>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="dashboard-card">
                <div class="card-top">
                    <div>
                        <h6>Pets</h6>
                        <h2>@Db.Pets.Count()</h2>
                    </div>
                    <div class="card-icon green">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </div>
                </div>
                <a href="/pets" class="card-link">View Details</a>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="dashboard-card">
                <div class="card-top">
                    <div>
                        <h6>Stays</h6>
                        <h2>@Db.Stays.Count()</h2>
                    </div>
                    <div class="card-icon orange">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                </div>
                <a href="/stays" class="card-link">View Details</a>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="dashboard-card">
                <div class="card-top">
                    <div>
                        <h6>Users</h6>
                        <h2>@Db.Users.Count()</h2>
                    </div>
                    <div class="card-icon dark">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
                <a href="/users" class="card-link">View Details</a>
            </div>
        </div>

    </div>

    <div class="row g-4 mt-4">

        <div class="col-lg-7">
            <div class="panel-card">
                <div class="panel-header">
                    <h4>Calendar</h4>
                    <span>@currentMonth.ToString("MMMM yyyy")</span>
                </div>

                <div class="calendar-grid calendar-header">
                    <div>Mon</div>
                    <div>Tue</div>
                    <div>Wed</div>
                    <div>Thu</div>
                    <div>Fri</div>
                    <div>Sat</div>
                    <div>Sun</div>
                </div>

                <div class="calendar-grid">
                    @foreach (var day in calendarDays)
                    {
                        <div class="calendar-day @(day.Month != currentMonth.Month ? "muted" : "") @(day.Date == DateTime.Today ? "today" : "")">
                            @day.Day
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="panel-card h-100">
                <div class="panel-header">
                    <h4>Quick Actions</h4>
                </div>

                <div class="quick-actions">
                    <a href="/clients/new">New Client</a>
                    <a href="/pets/new">New Pet</a>
                    <a href="/stays/new">New Stay</a>
                    <a href="/users/new">New User</a>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-4 mt-4">

        <div class="col-md-4">
            <div class="panel-card h-100">
                <div class="panel-header">
                    <h4>Recent Clients</h4>
                </div>

                <ul class="dashboard-list">
                    @foreach (var client in Db.Clients.OrderByDescending(c => c.ClientId).Take(3))
                    {
                        <li>@client.Name</li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-4">
            <div class="panel-card h-100">
                <div class="panel-header">
                    <h4>Recent Pets</h4>
                </div>

                <ul class="dashboard-list">
                    @foreach (var pet in Db.Pets.OrderByDescending(p => p.PetId).Take(3))
                    {
                        <li>@pet.Name - @pet.Species</li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-4">
            <div class="panel-card h-100">
                <div class="panel-header">
                    <h4>Upcoming Stays</h4>
                </div>

                <ul class="dashboard-list">
                    @foreach (var stay in Db.Stays.OrderBy(s => s.StartDate).Take(3))
                    {
                        <li>Pet ID @stay.PetId - @stay.StartDate.ToShortDateString()</li>
                    }
                </ul>
            </div>
        </div>

    </div>

</div>

@code {
    private DateTime currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private List<DateTime> calendarDays = new();

    protected override void OnInitialized()
    {
        BuildCalendar();
    }

    private void BuildCalendar()
    {
        var firstDay = currentMonth;
        var startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
        var calendarStart = firstDay.AddDays(-startOffset);

        calendarDays = Enumerable.Range(0, 42)
            .Select(i => calendarStart.AddDays(i))
            .ToList();
    }
}